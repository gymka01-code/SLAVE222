# ─── Telegram ─────────────────────────────────────────────────────
# Токен бота от @BotFather
BOT_TOKEN=8606742629:AAE0l0AylYWg7Rjgk167GBkchFjBEtf2JFw

# Публичный HTTPS-URL, по которому открывается WebApp (без слэша в конце)
# Должен быть доступен из интернета (ngrok / ваш домен / VPS)
WEBAPP_URL=https://slave222-production.up.railway.app

# ID администраторов через запятую (без пробелов)
ADMIN_IDS=7502434760

# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=rabstvo
POSTGRES_PASSWORD=super_secret_password
POSTGRES_DB=rabstvo

# asyncpg DSN — используется бэкендом напрямую
DATABASE_URL=postgresql://rabstvo:super_secret_password@db:5432/rabstvo

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Прочее ───────────────────────────────────────────────────────
# Хост и порт FastAPI-сервера внутри контейнера
APP_HOST=0.0.0.0
APP_PORT=8000
